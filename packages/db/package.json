{
  "name": "@secret-manager/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "tsc --noEmit",
    "db:generate": "prisma generate --schema prisma/schema.prisma",
    "db:generate:postgres": "prisma generate --schema prisma/schema.postgres.prisma",
    "db:migrate": "prisma migrate dev --schema prisma/schema.prisma",
    "db:push:postgres": "prisma db push --schema prisma/schema.postgres.prisma",
    "db:seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "@secret-manager/crypto": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "24.10.2",
    "prisma": "6.19.3",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
