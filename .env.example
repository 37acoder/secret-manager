# Copy to .env.local for local development. Use fake/demo values only.
# Generate a fake 32-byte base64 key with:
#   openssl rand -base64 32
SM_MASTER_KEY="base64-encoded-32-byte-demo-key"
SM_KEY_VERSION="v1"
DATABASE_URL="file:./dev.db"
SECRET_MANAGER_SQLITE_PATH=".secret-manager/state.sqlite"
SESSION_COOKIE_NAME="sm_session"
